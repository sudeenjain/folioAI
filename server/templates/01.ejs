<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= hero.name %> | Portfolio</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'JetBrains Mono', monospace; background: #0d0d0d; color: #00ff41; }
        .cursor { display: inline-block; width: 10px; height: 20px; background: #00ff41; animation: blink 1s infinite; }
        @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
        .terminal-card { border: 1px solid #00ff41; padding: 1rem; margin-bottom: 1rem; }
    </style>
</head>
<body class="p-4 md:p-12 max-w-4xl mx-auto">
    <header class="mb-12 flex flex-col md:flex-row gap-8 items-start">
        <% if (hero.photo_url) { %>
            <img src="<%= hero.photo_url %>" alt="<%= hero.name %>" class="w-32 h-32 rounded-lg border border-[#00ff41] object-cover">
        <% } %>
        <div class="flex-1">
            <div class="text-xl mb-2">$ whoami</div>
            <h1 class="text-4xl md:text-6xl font-bold mb-4"><%= hero.name %></h1>
            <div class="text-xl opacity-80"><%= hero.title %></div>
            <% if (hero.location) { %>
                <div class="text-sm opacity-60 mt-1">Location: <%= hero.location %></div>
            <% } %>
            <div class="mt-4"><%= hero.tagline %><span class="cursor"></span></div>
        </div>
    </header>

    <% if (hero.objective) { %>
    <section class="mb-12">
        <div class="text-xl mb-4">$ cat objective.txt</div>
        <p class="leading-relaxed italic opacity-80"><%= hero.objective %></p>
    </section>
    <% } %>

    <section class="mb-12">
        <div class="text-xl mb-4">$ cat about.txt</div>
        <p class="leading-relaxed"><%= about.bio %></p>
    </section>

    <section class="mb-12">
        <div class="text-xl mb-4">$ ls projects/</div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <% projects.forEach(project => { %>
                <div class="terminal-card">
                    <h3 class="text-xl font-bold mb-2"><%= project.name %></h3>
                    <p class="text-sm mb-4 opacity-80"><%= project.description %></p>
                    <% if (project.tech_stack) { %>
                    <div class="flex flex-wrap gap-2 mb-4">
                        <% project.tech_stack.forEach(tag => { %>
                            <span class="text-xs border border-[#00ff41] px-2 py-1"><%= tag %></span>
                        <% }); %>
                    </div>
                    <% } %>
                    <div class="flex gap-4 text-sm">
                        <% if (project.github_url) { %>
                            <a href="<%= project.github_url %>" target="_blank" class="underline">github</a>
                        <% } %>
                        <% if (project.live_url) { %>
                            <a href="<%= project.live_url %>" target="_blank" class="underline">live_demo</a>
                        <% } %>
                    </div>
                </div>
            <% }); %>
        </div>
    </section>

    <section class="mb-12">
        <div class="text-xl mb-4">$ ./skills.sh</div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <% if (skills.technical_skills && skills.technical_skills.length) { %>
            <div>
                <div class="font-bold mb-2">Technical:</div>
                <ul class="text-sm">
                    <% skills.technical_skills.forEach(s => { %> <li>- <%= s %></li> <% }); %>
                </ul>
            </div>
            <% } %>
            <% if (skills.languages && skills.languages.length) { %>
            <div>
                <div class="font-bold mb-2">Languages:</div>
                <ul class="text-sm">
                    <% skills.languages.forEach(s => { %> <li>- <%= s %></li> <% }); %>
                </ul>
            </div>
            <% } %>
            <% if (skills.frameworks && skills.frameworks.length) { %>
            <div>
                <div class="font-bold mb-2">Frameworks:</div>
                <ul class="text-sm">
                    <% skills.frameworks.forEach(s => { %> <li>- <%= s %></li> <% }); %>
                </ul>
            </div>
            <% } %>
            <% if (skills.tools && skills.tools.length) { %>
            <div>
                <div class="font-bold mb-2">Tools:</div>
                <ul class="text-sm">
                    <% skills.tools.forEach(s => { %> <li>- <%= s %></li> <% }); %>
                </ul>
            </div>
            <% } %>
        </div>
    </section>

    <% if (experience && experience.length) { %>
    <section class="mb-12">
        <div class="text-xl mb-4">$ history | grep work</div>
        <div class="space-y-6">
            <% experience.forEach(exp => { %>
                <div class="border-l-2 border-[#00ff41] pl-4">
                    <div class="flex justify-between items-start mb-1">
                        <h3 class="font-bold text-lg"><%= exp.role %> @ <%= exp.company %></h3>
                        <span class="text-xs opacity-60"><%= exp.duration %></span>
                    </div>
                    <ul class="text-sm space-y-1 opacity-80">
                        <% exp.responsibilities.forEach(res => { %>
                            <li>> <%= res %></li>
                        <% }); %>
                    </ul>
                </div>
            <% }); %>
        </div>
    </section>
    <% } %>

    <% if (education && education.length) { %>
    <section class="mb-12">
        <div class="text-xl mb-4">$ cat education.log</div>
        <div class="space-y-4">
            <% education.forEach(edu => { %>
                <div>
                    <div class="font-bold"><%= edu.degree %></div>
                    <div class="text-sm opacity-80"><%= edu.institution %> | <%= edu.year %></div>
                </div>
            <% }); %>
        </div>
    </section>
    <% } %>

    <% if (certifications && certifications.length) { %>
    <section class="mb-12">
        <div class="text-xl mb-4">$ ls certs/</div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <% certifications.forEach(cert => { %>
                <div class="text-sm">
                    <div class="font-bold"><%= cert.name %></div>
                    <div class="opacity-60"><%= cert.issuer %> (<%= cert.year %>)</div>
                </div>
            <% }); %>
        </div>
    </section>
    <% } %>

    <footer class="mt-24 pt-8 border-t border-[#00ff41] text-sm opacity-60">
        <div class="flex gap-4">
            <% if (contact.email) { %><a href="mailto:<%= contact.email %>" class="hover:underline">email</a><% } %>
            <% if (contact.github) { %><a href="<%= contact.github %>" class="hover:underline">github</a><% } %>
            <% if (contact.linkedin) { %><a href="<%= contact.linkedin %>" class="hover:underline">linkedin</a><% } %>
        </div>
        <div class="mt-4">© <%= new Date().getFullYear() %> <%= hero.name %></div>
    </footer>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script>gsap.from("section", { opacity: 0, y: 20, duration: 0.8, stagger: 0.2 });</script>
</body>
</html>
