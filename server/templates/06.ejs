<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= hero.name %> | Portfolio</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Lora', serif; background: #fafaf0; color: #2c2c2c; }
        .accent { color: #8b0000; }
    </style>
</head>
<body class="p-8 md:p-24 max-w-4xl mx-auto border-x border-gray-200 min-h-screen">
    <header class="text-center mb-24">
        <% if (hero.photo_url) { %>
            <img src="<%= hero.photo_url %>" alt="<%= hero.name %>" class="w-32 h-32 rounded-full mx-auto mb-8 sepia hover:sepia-0 transition-all duration-700">
        <% } %>
        <h1 class="text-5xl font-bold mb-4"><%= hero.name %></h1>
        <p class="text-xl italic accent"><%= hero.title %></p>
        <% if (hero.location) { %>
            <p class="text-sm opacity-50 mt-2"><%= hero.location %></p>
        <% } %>
    </header>

    <% if (hero.objective) { %>
    <section class="mb-24">
        <h2 class="text-2xl font-bold mb-8 border-b border-gray-300 pb-2 uppercase tracking-widest">Objective</h2>
        <p class="text-lg italic opacity-70 leading-relaxed"><%= hero.objective %></p>
    </section>
    <% } %>

    <section id="about" class="mb-24">
        <h2 class="text-2xl font-bold mb-8 border-b border-gray-300 pb-2 uppercase tracking-widest">Biography</h2>
        <p class="text-lg leading-relaxed"><%= about.bio %></p>
    </section>

    <section id="projects" class="mb-24">
        <h2 class="text-2xl font-bold mb-8 border-b border-gray-300 pb-2 uppercase tracking-widest">Selected Works</h2>
        <div class="space-y-16">
            <% projects.forEach(project => { %>
                <div>
                    <h3 class="text-2xl font-bold underline mb-4"><%= project.name %></h3>
                    <p class="text-gray-600 mb-6 leading-relaxed"><%= project.description %></p>
                    <% if (project.tech_stack) { %>
                        <div class="flex flex-wrap gap-4 mb-6 text-sm italic opacity-60">
                            <% project.tech_stack.forEach(tag => { %>
                                <span>#<%= tag %></span>
                            <% }); %>
                        </div>
                    <% } %>
                    <div class="flex gap-8 text-sm font-bold uppercase tracking-widest">
                        <% if (project.github_url) { %>
                            <a href="<%= project.github_url %>" class="accent hover:underline">Repository</a>
                        <% } %>
                        <% if (project.live_url) { %>
                            <a href="<%= project.live_url %>" class="accent hover:underline">Live View</a>
                        <% } %>
                    </div>
                </div>
            <% }); %>
        </div>
    </section>

    <section class="mb-24">
        <h2 class="text-2xl font-bold mb-8 border-b border-gray-300 pb-2 uppercase tracking-widest">Expertise</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
            <% if (skills.technical_skills && skills.technical_skills.length) { %>
            <div>
                <h4 class="font-bold mb-4 italic">Technical</h4>
                <ul class="space-y-2 text-gray-600">
                    <% skills.technical_skills.forEach(s => { %> <li>— <%= s %></li> <% }); %>
                </ul>
            </div>
            <% } %>
            <% if (skills.languages && skills.languages.length) { %>
            <div>
                <h4 class="font-bold mb-4 italic">Languages</h4>
                <ul class="space-y-2 text-gray-600">
                    <% skills.languages.forEach(s => { %> <li>— <%= s %></li> <% }); %>
                </ul>
            </div>
            <% } %>
            <% if (skills.frameworks && skills.frameworks.length) { %>
            <div>
                <h4 class="font-bold mb-4 italic">Frameworks</h4>
                <ul class="space-y-2 text-gray-600">
                    <% skills.frameworks.forEach(s => { %> <li>— <%= s %></li> <% }); %>
                </ul>
            </div>
            <% } %>
            <% if (skills.tools && skills.tools.length) { %>
            <div>
                <h4 class="font-bold mb-4 italic">Tools</h4>
                <ul class="space-y-2 text-gray-600">
                    <% skills.tools.forEach(s => { %> <li>— <%= s %></li> <% }); %>
                </ul>
            </div>
            <% } %>
        </div>
    </section>

    <% if (experience && experience.length) { %>
    <section class="mb-24">
        <h2 class="text-2xl font-bold mb-8 border-b border-gray-300 pb-2 uppercase tracking-widest">Professional History</h2>
        <div class="space-y-16">
            <% experience.forEach(exp => { %>
                <div>
                    <div class="flex justify-between items-baseline mb-4">
                        <h3 class="text-xl font-bold"><%= exp.role %> <span class="accent">at</span> <%= exp.company %></h3>
                        <span class="text-sm italic opacity-50"><%= exp.duration %></span>
                    </div>
                    <ul class="space-y-4 text-gray-600 italic">
                        <% exp.responsibilities.forEach(res => { %>
                            <li class="flex gap-4">
                                <span class="accent">¶</span>
                                <span><%= res %></span>
                            </li>
                        <% }); %>
                    </ul>
                </div>
            <% }); %>
        </div>
    </section>
    <% } %>

    <% if (education && education.length || certifications && certifications.length) { %>
    <section class="mb-24 space-y-16">
        <% if (education && education.length) { %>
        <div>
            <h2 class="text-2xl font-bold mb-8 border-b border-gray-300 pb-2 uppercase tracking-widest">Academic Background</h2>
            <div class="space-y-6">
                <% education.forEach(edu => { %>
                    <div>
                        <h3 class="font-bold"><%= edu.degree %></h3>
                        <p class="italic text-gray-600"><%= edu.institution %>, <%= edu.year %></p>
                    </div>
                <% }); %>
            </div>
        </div>
        <% } %>
        <% if (certifications && certifications.length) { %>
        <div>
            <h2 class="text-2xl font-bold mb-8 border-b border-gray-300 pb-2 uppercase tracking-widest">Certifications</h2>
            <div class="space-y-6">
                <% certifications.forEach(cert => { %>
                    <div>
                        <h3 class="font-bold"><%= cert.name %></h3>
                        <p class="italic text-gray-600"><%= cert.issuer %>, <%= cert.year %></p>
                    </div>
                <% }); %>
            </div>
        </div>
        <% } %>
    </section>
    <% } %>
    <footer id="contact" class="pt-12 border-t border-gray-300 text-center text-sm italic space-y-4">
        <% if (contact.email) { %><p><%= contact.email %></p><% } %>
        <div class="flex justify-center gap-8 not-italic font-bold uppercase tracking-widest text-[10px] accent">
            <% if (contact.github) { %><a href="<%= contact.github %>" class="hover:underline">GitHub</a><% } %>
            <% if (contact.linkedin) { %><a href="<%= contact.linkedin %>" class="hover:underline">LinkedIn</a><% } %>
        </div>
    </footer>
</body>
</html>
