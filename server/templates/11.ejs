<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= hero.name %> | Portfolio</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'IBM Plex Sans', sans-serif; background: #f8fafc; color: #1e293b; }
        .card { background: white; border: 1px solid #e2e8f0; border-radius: 1rem; padding: 1.5rem; }
    </style>
</head>
<body class="p-4 md:p-8">
    <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
            <div class="card md:col-span-3 flex flex-col md:flex-row gap-8 items-center md:items-start">
                <% if (hero.photo_url) { %>
                    <img src="<%= hero.photo_url %>" alt="<%= hero.name %>" class="w-32 h-32 rounded-xl object-cover">
                <% } %>
                <div>
                    <h1 class="text-4xl font-bold mb-2"><%= hero.name %></h1>
                    <p class="text-gray-500 mb-4"><%= hero.title %></p>
                    <div class="flex flex-wrap gap-4 text-xs text-gray-400">
                        <% if (hero.location) { %>
                            <span class="flex items-center gap-1">
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                                <%= hero.location %>
                            </span>
                        <% } %>
                        <% if (contact && contact.email) { %>
                        <span class="flex items-center gap-1">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                            <%= contact.email %>
                        </span>
                        <% } %>
                    </div>
                </div>
            </div>
            <div class="card flex flex-col justify-center items-center text-center">
                <h4 class="text-xs font-bold text-gray-400 uppercase mb-4 tracking-widest">Connect</h4>
                <div class="flex gap-4">
                    <% if (contact && contact.github) { %>
                    <a href="<%= contact.github %>" class="p-2 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                    </a>
                    <% } %>
                    <% if (contact && contact.linkedin) { %>
                    <a href="<%= contact.linkedin %>" class="p-2 bg-gray-50 rounded-lg hover:bg-gray-100 transition-colors">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                    </a>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="md:col-span-2 space-y-6">
                <% if (hero.objective) { %>
                <div class="card bg-blue-50 border-blue-100">
                    <h2 class="text-sm font-bold uppercase text-blue-400 mb-4">Objective</h2>
                    <p class="text-lg italic text-blue-900"><%= hero.objective %></p>
                </div>
                <% } %>

                <div class="card">
                    <h2 class="text-sm font-bold uppercase text-gray-400 mb-6">Overview</h2>
                    <p class="text-lg leading-relaxed"><%= about.bio %></p>
                </div>

                <div class="card">
                    <h2 class="text-sm font-bold uppercase text-gray-400 mb-8">Projects</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <% projects.forEach(project => { %>
                            <div class="group">
                                <h3 class="font-bold text-xl mb-2 group-hover:text-blue-600 transition-colors"><%= project.name %></h3>
                                <p class="text-sm text-gray-500 mb-4"><%= project.description %></p>
                                <% if (project.tech_stack) { %>
                                    <div class="flex flex-wrap gap-2 mb-4">
                                        <% project.tech_stack.forEach(tag => { %>
                                            <span class="text-[10px] bg-gray-100 px-2 py-1 rounded"><%= tag %></span>
                                        <% }); %>
                                    </div>
                                <% } %>
                                <div class="flex gap-4">
                                    <% if (project.github_url) { %>
                                        <a href="<%= project.github_url %>" class="text-xs font-semibold text-blue-600 hover:underline">Code</a>
                                    <% } %>
                                    <% if (project.live_url) { %>
                                        <a href="<%= project.live_url %>" class="text-xs font-semibold text-blue-600 hover:underline">Live</a>
                                    <% } %>
                                </div>
                            </div>
                        <% }); %>
                    </div>
                </div>

                <% if (experience && experience.length) { %>
                <div class="card">
                    <h2 class="text-sm font-bold uppercase text-gray-400 mb-8">Experience</h2>
                    <div class="space-y-8">
                        <% experience.forEach(exp => { %>
                            <div class="relative pl-8 border-l-2 border-gray-100">
                                <div class="absolute -left-[9px] top-0 w-4 h-4 rounded-full bg-white border-2 border-blue-600"></div>
                                <div class="flex flex-col md:flex-row justify-between mb-4">
                                    <h3 class="font-bold text-xl"><%= exp.role %></h3>
                                    <span class="text-sm text-gray-400 font-mono"><%= exp.duration %></span>
                                </div>
                                <p class="text-blue-600 font-semibold mb-4"><%= exp.company %></p>
                                <ul class="space-y-2 text-sm text-gray-600">
                                    <% exp.responsibilities.forEach(res => { %>
                                        <li class="flex gap-2"><span>•</span><span><%= res %></span></li>
                                    <% }); %>
                                </ul>
                            </div>
                        <% }); %>
                    </div>
                </div>
                <% } %>
            </div>

            <div class="space-y-6">
                <div class="card">
                    <h2 class="text-sm font-bold uppercase text-gray-400 mb-6">Skills</h2>
                    <div class="space-y-6">
                        <% if (skills.technical_skills && skills.technical_skills.length) { %>
                            <div>
                                <h4 class="text-xs font-bold text-gray-300 mb-3 uppercase">Technical</h4>
                                <div class="flex flex-wrap gap-2">
                                    <% skills.technical_skills.forEach(s => { %>
                                        <span class="px-2 py-1 bg-gray-50 text-gray-600 rounded text-xs"><%= s %></span>
                                    <% }); %>
                                </div>
                            </div>
                        <% } %>
                        <% if (skills.languages && skills.languages.length) { %>
                            <div>
                                <h4 class="text-xs font-bold text-gray-300 mb-3 uppercase">Languages</h4>
                                <div class="flex flex-wrap gap-2">
                                    <% skills.languages.forEach(s => { %>
                                        <span class="px-2 py-1 bg-gray-50 text-gray-600 rounded text-xs"><%= s %></span>
                                    <% }); %>
                                </div>
                            </div>
                        <% } %>
                        <% if (skills.frameworks && skills.frameworks.length) { %>
                            <div>
                                <h4 class="text-xs font-bold text-gray-300 mb-3 uppercase">Frameworks</h4>
                                <div class="flex flex-wrap gap-2">
                                    <% skills.frameworks.forEach(s => { %>
                                        <span class="px-2 py-1 bg-gray-50 text-gray-600 rounded text-xs"><%= s %></span>
                                    <% }); %>
                                </div>
                            </div>
                        <% } %>
                        <% if (skills.tools && skills.tools.length) { %>
                            <div>
                                <h4 class="text-xs font-bold text-gray-300 mb-3 uppercase">Tools</h4>
                                <div class="flex flex-wrap gap-2">
                                    <% skills.tools.forEach(s => { %>
                                        <span class="px-2 py-1 bg-gray-50 text-gray-600 rounded text-xs"><%= s %></span>
                                    <% }); %>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>

                <% if (education && education.length) { %>
                <div class="card">
                    <h2 class="text-sm font-bold uppercase text-gray-400 mb-6">Education</h2>
                    <div class="space-y-6">
                        <% education.forEach(edu => { %>
                            <div>
                                <h3 class="font-bold text-sm"><%= edu.degree %></h3>
                                <p class="text-xs text-gray-500 mt-1"><%= edu.institution %> | <%= edu.year %></p>
                            </div>
                        <% }); %>
                    </div>
                </div>
                <% } %>

                <% if (certifications && certifications.length) { %>
                <div class="card">
                    <h2 class="text-sm font-bold uppercase text-gray-400 mb-6">Certifications</h2>
                    <div class="space-y-6">
                        <% certifications.forEach(cert => { %>
                            <div>
                                <h3 class="font-bold text-sm"><%= cert.name %></h3>
                                <p class="text-xs text-gray-500 mt-1"><%= cert.issuer %> (<%= cert.year %>)</p>
                            </div>
                        <% }); %>
                    </div>
                </div>
                <% } %>
            </div>
        </div>
    </div>
</body>
</html>
