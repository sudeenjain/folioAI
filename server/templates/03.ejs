<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= hero.name %> | Portfolio</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: #0f0f0f; color: #e5e5e5; }
        .section-title { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.2em; color: #666; margin-bottom: 2rem; }
        .accent { color: #6c63ff; }
    </style>
</head>
<body class="px-6 py-12 md:px-24 md:py-24 max-w-5xl mx-auto">
    <header class="mb-32 flex flex-col md:flex-row gap-12 items-center">
        <% if (hero.photo_url) { %>
            <div class="relative">
                <img src="<%= hero.photo_url %>" alt="<%= hero.name %>" class="w-48 h-48 object-cover rounded-full border-2 border-[#6c63ff] p-1">
                <div class="absolute -bottom-2 -right-2 bg-[#6c63ff] text-white px-3 py-1 text-[10px] font-bold rounded-full">AVAILABLE</div>
            </div>
        <% } %>
        <div>
            <h1 class="text-6xl md:text-8xl font-light tracking-tighter mb-6"><%= hero.name %><span class="accent">.</span></h1>
            <p class="text-xl md:text-2xl text-gray-500 max-w-2xl"><%= hero.title %>. <%= hero.tagline %></p>
            <% if (hero.location) { %>
                <p class="text-sm text-gray-600 mt-2 flex items-center gap-2">
                    <span class="w-2 h-2 bg-[#6c63ff] rounded-full"></span>
                    <%= hero.location %>
                </p>
            <% } %>
        </div>
    </header>

    <% if (hero.objective) { %>
    <section class="mb-32">
        <h2 class="section-title">Objective</h2>
        <p class="text-xl md:text-2xl font-light text-gray-400 border-l-2 border-[#6c63ff] pl-8 py-2"><%= hero.objective %></p>
    </section>
    <% } %>

    <section class="mb-32">
        <h2 class="section-title">About</h2>
        <p class="text-2xl md:text-3xl leading-tight font-light"><%= about.bio %></p>
    </section>

    <section class="mb-32">
        <h2 class="section-title">Projects</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <% projects.forEach(project => { %>
                <div class="p-8 border border-gray-800 hover:border-[#6c63ff] transition-colors duration-300 group">
                    <h3 class="text-2xl font-semibold mb-4 group-hover:accent transition-colors"><%= project.name %></h3>
                    <p class="text-gray-500 mb-6"><%= project.description %></p>
                    <% if (project.tech_stack) { %>
                        <div class="flex flex-wrap gap-2 mb-6">
                            <% project.tech_stack.forEach(tag => { %>
                                <span class="text-[10px] bg-gray-900 text-gray-400 px-2 py-1 rounded"><%= tag %></span>
                            <% }); %>
                        </div>
                    <% } %>
                    <div class="flex gap-6">
                        <% if (project.github_url) { %>
                            <a href="<%= project.github_url %>" class="text-sm accent font-semibold tracking-widest uppercase hover:underline">Code</a>
                        <% } %>
                        <% if (project.live_url) { %>
                            <a href="<%= project.live_url %>" class="text-sm accent font-semibold tracking-widest uppercase hover:underline">Live</a>
                        <% } %>
                    </div>
                </div>
            <% }); %>
        </div>
    </section>

    <section class="mb-32">
        <h2 class="section-title">Skills</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
            <% if (skills.technical_skills && skills.technical_skills.length) { %>
            <div>
                <h4 class="text-[#6c63ff] font-semibold mb-6 text-xs tracking-widest uppercase">Technical</h4>
                <div class="flex flex-wrap gap-2">
                    <% skills.technical_skills.forEach(s => { %>
                        <span class="text-sm text-gray-400"><%= s %></span>
                    <% }); %>
                </div>
            </div>
            <% } %>
            <% if (skills.languages && skills.languages.length) { %>
            <div>
                <h4 class="text-[#6c63ff] font-semibold mb-6 text-xs tracking-widest uppercase">Languages</h4>
                <div class="flex flex-wrap gap-2">
                    <% skills.languages.forEach(s => { %>
                        <span class="text-sm text-gray-400"><%= s %></span>
                    <% }); %>
                </div>
            </div>
            <% } %>
            <% if (skills.frameworks && skills.frameworks.length) { %>
            <div>
                <h4 class="text-[#6c63ff] font-semibold mb-6 text-xs tracking-widest uppercase">Frameworks</h4>
                <div class="flex flex-wrap gap-2">
                    <% skills.frameworks.forEach(s => { %>
                        <span class="text-sm text-gray-400"><%= s %></span>
                    <% }); %>
                </div>
            </div>
            <% } %>
            <% if (skills.tools && skills.tools.length) { %>
            <div>
                <h4 class="text-[#6c63ff] font-semibold mb-6 text-xs tracking-widest uppercase">Tools</h4>
                <div class="flex flex-wrap gap-2">
                    <% skills.tools.forEach(s => { %>
                        <span class="text-sm text-gray-400"><%= s %></span>
                    <% }); %>
                </div>
            </div>
            <% } %>
        </div>
    </section>

    <% if (experience && experience.length) { %>
    <section class="mb-32">
        <h2 class="section-title">Experience</h2>
        <div class="space-y-12">
            <% experience.forEach(exp => { %>
                <div class="border-b border-gray-800 pb-12 last:border-0">
                    <div class="flex flex-col md:flex-row justify-between mb-6 gap-2">
                        <h3 class="text-3xl font-light"><%= exp.role %> <span class="accent">@</span> <%= exp.company %></h3>
                        <span class="text-gray-500 font-mono text-sm"><%= exp.duration %></span>
                    </div>
                    <ul class="space-y-4 max-w-3xl">
                        <% exp.responsibilities.forEach(res => { %>
                            <li class="text-gray-400 flex gap-4">
                                <span class="accent">▹</span>
                                <span><%= res %></span>
                            </li>
                        <% }); %>
                    </ul>
                </div>
            <% }); %>
        </div>
    </section>
    <% } %>

    <% if (education && education.length || certifications && certifications.length) { %>
    <section class="mb-32 grid grid-cols-1 md:grid-cols-2 gap-24">
        <% if (education && education.length) { %>
        <div>
            <h2 class="section-title">Education</h2>
            <div class="space-y-8">
                <% education.forEach(edu => { %>
                    <div>
                        <h3 class="text-xl font-semibold"><%= edu.degree %></h3>
                        <p class="text-gray-500 mt-1"><%= edu.institution %> — <%= edu.year %></p>
                    </div>
                <% }); %>
            </div>
        </div>
        <% } %>
        <% if (certifications && certifications.length) { %>
        <div>
            <h2 class="section-title">Certifications</h2>
            <div class="space-y-8">
                <% certifications.forEach(cert => { %>
                    <div>
                        <h3 class="text-xl font-semibold"><%= cert.name %></h3>
                        <p class="text-gray-500 mt-1"><%= cert.issuer %> (<%= cert.year %>)</p>
                    </div>
                <% }); %>
            </div>
        </div>
        <% } %>
    </section>
    <% } %>

    <footer class="pt-12 border-t border-gray-800 flex flex-col md:flex-row justify-between gap-8">
        <div>
            <div class="section-title mb-4">Get in touch</div>
            <% if (contact.email) { %><a href="mailto:<%= contact.email %>" class="text-2xl accent hover:underline"><%= contact.email %></a><% } %>
        </div>
        <div class="flex gap-6 items-end">
            <% if (contact.github) { %><a href="<%= contact.github %>" class="hover:text-white transition-colors">GitHub</a><% } %>
            <% if (contact.linkedin) { %><a href="<%= contact.linkedin %>" class="hover:text-white transition-colors">LinkedIn</a><% } %>
        </div>
    </footer>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <script>
        gsap.registerPlugin(ScrollTrigger);
        gsap.utils.toArray('section').forEach(section => {
            gsap.from(section, { opacity: 0, y: 30, duration: 0.8, scrollTrigger: { trigger: section, start: "top 85%" } });
        });
    </script>
</body>
</html>
