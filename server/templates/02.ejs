<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= hero.name %> | Portfolio</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background: #ffffff; color: #111111; }
        .section-title { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.2em; color: #666; margin-bottom: 2rem; }
    </style>
</head>
<body class="px-6 py-12 md:px-24 md:py-24 max-w-5xl mx-auto">
    <header class="mb-32 flex flex-col md:flex-row gap-12 items-start">
        <% if (hero.photo_url) { %>
            <img src="<%= hero.photo_url %>" alt="<%= hero.name %>" class="w-48 h-48 object-cover grayscale hover:grayscale-0 transition-all duration-500">
        <% } %>
        <div>
            <h1 class="text-6xl md:text-8xl font-light tracking-tighter mb-6"><%= hero.name %></h1>
            <p class="text-xl md:text-2xl text-gray-500 max-w-2xl"><%= hero.title %>. <%= hero.tagline %></p>
            <% if (hero.location) { %>
                <p class="text-sm text-gray-400 mt-2"><%= hero.location %></p>
            <% } %>
        </div>
    </header>

    <% if (hero.objective) { %>
    <section class="mb-32">
        <h2 class="section-title">Objective</h2>
        <p class="text-xl md:text-2xl font-light italic text-gray-600"><%= hero.objective %></p>
    </section>
    <% } %>

    <section class="mb-32">
        <h2 class="section-title">About</h2>
        <p class="text-2xl md:text-3xl leading-tight font-light"><%= about.bio %></p>
    </section>

    <section class="mb-32">
        <h2 class="section-title">Selected Projects</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
            <% projects.forEach(project => { %>
                <div class="group">
                    <h3 class="text-xl font-semibold mb-2"><%= project.name %></h3>
                    <p class="text-gray-500 mb-4"><%= project.description %></p>
                    <% if (project.tech_stack) { %>
                        <div class="flex flex-wrap gap-2 mb-4">
                            <% project.tech_stack.forEach(tag => { %>
                                <span class="text-[10px] uppercase tracking-widest text-gray-400 border border-gray-200 px-2 py-1"><%= tag %></span>
                            <% }); %>
                        </div>
                    <% } %>
                    <div class="flex gap-4">
                        <% if (project.github_url) { %>
                            <a href="<%= project.github_url %>" class="text-sm font-semibold border-b border-black pb-1">GitHub</a>
                        <% } %>
                        <% if (project.live_url) { %>
                            <a href="<%= project.live_url %>" class="text-sm font-semibold border-b border-black pb-1">Live Demo</a>
                        <% } %>
                    </div>
                </div>
            <% }); %>
        </div>
    </section>

    <section class="mb-32">
        <h2 class="section-title">Expertise</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
            <% if (skills.technical_skills && skills.technical_skills.length) { %>
            <div>
                <h4 class="font-semibold mb-4 text-sm">Technical</h4>
                <ul class="text-sm text-gray-500 space-y-2">
                    <% skills.technical_skills.forEach(s => { %> <li><%= s %></li> <% }); %>
                </ul>
            </div>
            <% } %>
            <% if (skills.languages && skills.languages.length) { %>
            <div>
                <h4 class="font-semibold mb-4 text-sm">Languages</h4>
                <ul class="text-sm text-gray-500 space-y-2">
                    <% skills.languages.forEach(s => { %> <li><%= s %></li> <% }); %>
                </ul>
            </div>
            <% } %>
            <% if (skills.frameworks && skills.frameworks.length) { %>
            <div>
                <h4 class="font-semibold mb-4 text-sm">Frameworks</h4>
                <ul class="text-sm text-gray-500 space-y-2">
                    <% skills.frameworks.forEach(s => { %> <li><%= s %></li> <% }); %>
                </ul>
            </div>
            <% } %>
            <% if (skills.tools && skills.tools.length) { %>
            <div>
                <h4 class="font-semibold mb-4 text-sm">Tools</h4>
                <ul class="text-sm text-gray-500 space-y-2">
                    <% skills.tools.forEach(s => { %> <li><%= s %></li> <% }); %>
                </ul>
            </div>
            <% } %>
        </div>
    </section>

    <% if (experience && experience.length) { %>
    <section class="mb-32">
        <h2 class="section-title">Experience</h2>
        <div class="space-y-16">
            <% experience.forEach(exp => { %>
                <div class="max-w-3xl">
                    <div class="flex justify-between items-baseline mb-4">
                        <h3 class="text-2xl font-light"><%= exp.role %> <span class="text-gray-400">at</span> <%= exp.company %></h3>
                        <span class="text-sm text-gray-400"><%= exp.duration %></span>
                    </div>
                    <ul class="space-y-3">
                        <% exp.responsibilities.forEach(res => { %>
                            <li class="text-gray-600 leading-relaxed flex gap-4">
                                <span class="text-gray-300">—</span>
                                <span><%= res %></span>
                            </li>
                        <% }); %>
                    </ul>
                </div>
            <% }); %>
        </div>
    </section>
    <% } %>

    <% if (education && education.length || certifications && certifications.length) { %>
    <section class="mb-32 grid grid-cols-1 md:grid-cols-2 gap-16">
        <% if (education && education.length) { %>
        <div>
            <h2 class="section-title">Education</h2>
            <div class="space-y-8">
                <% education.forEach(edu => { %>
                    <div>
                        <h3 class="font-semibold"><%= edu.degree %></h3>
                        <p class="text-gray-500"><%= edu.institution %>, <%= edu.year %></p>
                    </div>
                <% }); %>
            </div>
        </div>
        <% } %>
        <% if (certifications && certifications.length) { %>
        <div>
            <h2 class="section-title">Certifications</h2>
            <div class="space-y-8">
                <% certifications.forEach(cert => { %>
                    <div>
                        <h3 class="font-semibold"><%= cert.name %></h3>
                        <p class="text-gray-500"><%= cert.issuer %>, <%= cert.year %></p>
                    </div>
                <% }); %>
            </div>
        </div>
        <% } %>
    </section>
    <% } %>

    <footer class="pt-12 border-t border-gray-100 flex flex-col md:flex-row justify-between gap-8">
        <div>
            <div class="section-title mb-4">Contact</div>
            <% if (contact.email) { %><a href="mailto:<%= contact.email %>" class="text-2xl hover:text-gray-500"><%= contact.email %></a><% } %>
        </div>
        <div class="flex gap-6 items-end">
            <% if (contact.github) { %><a href="<%= contact.github %>" class="hover:opacity-50">GitHub</a><% } %>
            <% if (contact.linkedin) { %><a href="<%= contact.linkedin %>" class="hover:opacity-50">LinkedIn</a><% } %>
        </div>
    </footer>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <script>
        gsap.registerPlugin(ScrollTrigger);
        gsap.utils.toArray('section').forEach(section => {
            gsap.from(section, { opacity: 0, y: 50, duration: 1, scrollTrigger: { trigger: section, start: "top 80%" } });
        });
    </script>
</body>
</html>
