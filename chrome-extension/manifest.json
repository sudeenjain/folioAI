{
  "manifest_version": 3,
  "name": "FolioAI LinkedIn Extractor",
  "version": "1.0",
  "description": "Extracts LinkedIn profile data for FolioAI portfolio generation.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content.js"]
    }
  ]
}
